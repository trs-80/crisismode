{
  "name": "crisismode",
  "version": "0.5.0",
  "description": "AI-powered infrastructure recovery — detect, diagnose, and recover stateful systems",
  "type": "module",
  "bin": {
    "crisismode": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "keywords": [
    "crisis",
    "recovery",
    "infrastructure",
    "postgresql",
    "redis",
    "etcd",
    "kafka",
    "kubernetes",
    "diagnosis",
    "ai",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/trs-80/crisismode.git"
  },
  "homepage": "https://crisismode.ai",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "pnpm --filter @crisismode/agent-sdk run build && tsc",
    "build:bundle": "node scripts/esbuild.config.mjs",
    "build:binary": "bash scripts/build-binary.sh",
    "start": "node dist/index.js",
    "live": "tsx src/live.ts",
    "webhook": "tsx src/webhook.ts",
    "init": "tsx src/init.ts",
    "test": "vitest run",
    "test:cli": "bash test/cli/smoke.sh",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "pnpm --filter @crisismode/agent-sdk run build && tsc --noEmit",
    "prepare": "husky",
    "eval:diagnosis": "tsx eval/run-diagnosis-eval.ts"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@crisismode/agent-sdk": "workspace:*",
    "@kubernetes/client-node": "^1.4.0",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "semver": "^7.8.5",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1080.0",
    "@aws-sdk/client-rds": "^3.1080.0",
    "@aws-sdk/client-s3": "^3.1080.0",
    "@aws-sdk/client-sts": "^3.1080.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.23.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": "tsc --noEmit"
  }
}
