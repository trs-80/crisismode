{
  "name": "crisismode",
  "version": "0.2.0",
  "description": "Recovery Agent Contract Framework - Interactive CLI Demo",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "live": "tsx src/live.ts",
    "webhook": "tsx src/webhook.ts",
    "init": "tsx src/init.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "pg": "^8.16.3",
    "semver": "^7.7.4",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@types/node": "^20.11.0",
    "@types/semver": "^7.7.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.73.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": "tsc --noEmit"
  }
}
