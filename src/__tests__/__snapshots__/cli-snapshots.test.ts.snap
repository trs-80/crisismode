// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`CLI snapshot — error formatting > CrisisModeError with suggestion 1`] = `
"Error: Database connection lost
  Suggestion: Check pg_hba.conf and restart"
`;

exports[`CLI snapshot — error formatting > agentNotFound 1`] = `
"Error: No agent handles "mysql"
  Suggestion: Supported systems: postgresql, redis, etcd, kafka, kubernetes, ceph, flink, application, ai-provider, managed-database, message-queue, application-config"
`;

exports[`CLI snapshot — error formatting > connectionRefused — postgresql 1`] = `
"Error: Connection refused: db.local:5432 (postgresql)
  Suggestion: Is PostgreSQL running? Try: docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=secret postgres:16"
`;

exports[`CLI snapshot — error formatting > connectionRefused — unknown kind 1`] = `
"Error: Connection refused: db.local:3306 (mysql)
  Suggestion: Ensure mysql is running on db.local:3306"
`;

exports[`CLI snapshot — error formatting > missingEnvVar 1`] = `
"Error: Missing environment variable: PG_PASSWORD
  Suggestion: Set PG_PASSWORD: export PG_PASSWORD=<value>  (database authentication)"
`;

exports[`CLI snapshot — error formatting > noConfig 1`] = `
"Error: No configuration found and no services detected on localhost
  Suggestion: Run \`crisismode init\` to generate crisismode.yaml, or start a database first."
`;

exports[`CLI snapshot — error formatting > non-Error value 1`] = `"Error: 42"`;

exports[`CLI snapshot — error formatting > plain Error 1`] = `"Error: unexpected EOF"`;

exports[`CLI snapshot — escalation badges > level 1 — Observe 1`] = `"Observe"`;

exports[`CLI snapshot — escalation badges > level 2 — Diagnose 1`] = `"Diagnose"`;

exports[`CLI snapshot — escalation badges > level 3 — Suggest 1`] = `"Suggest"`;

exports[`CLI snapshot — escalation badges > level 4 — Repair 1`] = `"Repair"`;

exports[`CLI snapshot — escalation badges > level 5 — Repair! 1`] = `"Repair!"`;

exports[`CLI snapshot — health status JSON > health assessment in JSON mode 1`] = `
{
  "assessment": {
    "confidence": 0.85,
    "observedAt": "<<TIMESTAMP>>",
